# Admin seed (tài khoản quản trị mặc định)
ADMIN_CODE=degoadmin
ADMIN_PASSWORD=dego2026

# Cloudflare R2 (file đính kèm) — điền giá trị thật, KHÔNG commit .env
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_BUCKET=nexterp-storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Frontend (Vite đọc lúc dev)
