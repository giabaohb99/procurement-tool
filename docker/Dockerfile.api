# Backend API — FastAPI (dev: hot reload qua volume mount)
FROM python:3.12-slim

WORKDIR /app

# Cài dependency trước -> tận dụng cache, chỉ build lại khi requirements đổi
COPY backend/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# Code sẽ được mount qua volume khi dev; COPY để chạy được cả khi không mount
COPY backend/ /app/

CMD ["sh", "start.sh"]
